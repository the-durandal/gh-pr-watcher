{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "electron"],
    "lib": ["ES2021", "DOM"]
  },
  "include": ["main.ts", "preload.ts", "renderer/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
